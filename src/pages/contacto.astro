---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Reviews from "../components/Reviews.astro";

// Import banner
// Vite resolverá la extensión automáticamente, o asumirá si no hay.
import bannerContacto from "../img/Banner contacto.jpg";
---

<Layout title="Contacto | Agencias Nacionales S.A.S">
  <Navbar />
  <main class="w-full bg-white">
    <!-- Hero Section -->
    <section class="w-full sm:px-4 lg:px-6 mt-4">
      <div
        class="relative w-full h-[450px] overflow-hidden bg-stone-800 sm:rounded-3xl md:h-[500px]"
      >
        <img
          src={bannerContacto.src}
          alt="Contacto Agencias Nacionales"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/40"></div>
        <div
          class="absolute inset-0 z-10 flex h-full items-center justify-center px-6"
        >
          <div
            class="w-full max-w-[90%] text-center sm:mx-auto sm:max-w-4xl lg:max-w-6xl"
          >
            <h1
              class="mt-3 text-2xl font-extrabold leading-tight text-white drop-shadow-lg sm:mt-5 sm:text-4xl lg:text-5xl"
            >
              Contáctanos
            </h1>
            <p
              class="mt-3 max-w-lg text-base leading-relaxed text-white/95 drop-shadow sm:mx-auto sm:mt-4 sm:text-lg font-medium"
            >
              Estamos aquí para ayudarte. Contáctanos y descubre cómo podemos
              brindarle a tu empresa las mejores soluciones.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cards Section -->
    <section class="max-w-[1200px] mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Location Card -->
        <div
          class="bg-white rounded-[1.5rem] shadow-[0_4px_24px_rgb(0,0,0,0.06)] p-8 text-center flex flex-col items-center border border-gray-50 transition-shadow hover:shadow-[0_8px_30px_rgb(0,0,0,0.1)]"
        >
          <div
            class="w-16 h-16 rounded-[1rem] bg-blue-50 text-blue-600 flex items-center justify-center mb-5"
          >
            <svg
              class="w-7 h-7 fill-current"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 380 341"
            >
              <path
