---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import bannerFAQ from "../img/Banner FAQ.webp";

const categories = [
  {
    id: "uniformes-personalizados",
    title: "Uniformes Personalizados",
    faqs: [
      {
        question: "¿Cuánto tiempo tarda el proceso de producción de uniformes personalizados?",
        answer: "Dependiendo de la prenda y de la cantidad, el tiempo máximo del proceso es de 45 días calendario."
      },
      {
        question: "¿Se pueden personalizar los uniformes?",
        answer: "Sí, ofrecemos diversas técnicas de marcación como bordado, serigrafía y vinilo textil, adaptadas a tus necesidades para asegurar durabilidad y calidad."
      },
      {
        question: "¿Hay descuentos disponibles para pedidos al por mayor?",
        answer: "Sí, manejamos precios especiales según el volumen del pedido. Contáctanos para recibir una cotización personalizada acorde a la cantidad que necesitas."
      },
      {
        question: "¿Tienen opciones de diseño específicas para diferentes industrias?",
        answer: "Contamos con soluciones diseñadas para múltiples sectores, garantizando que cada uniforme cumpla con los requisitos de funcionalidad, seguridad y normativa de tu industria."
      }
    ]
  },
  {
    id: "proceso-cotizacion",
    title: "Proceso de Cotización y Pedido",
    faqs: [
      {
        question: "¿Cuál es el proceso para solicitar una cotización?",
        answer: "Puedes solicitarla a través de nuestro botón 'Escríbenos' o contactándonos directamente. Nuestro equipo te guiará paso a paso según tus requerimientos."
      }
    ]
  },
  {
    id: "epp",
    title: "Elementos de Protección Personal",
    faqs: [
      {
        question: "¿Realizan pruebas de resistencia en sus productos?",
        answer: "Sí, todos nuestros productos son sometidos a rigurosas pruebas de resistencia para garantizar la máxima protección y rendimiento de tu equipo."
      },
      {
        question: "¿Cómo aseguran la durabilidad del equipo de protección personal?",
        answer: "Nuestros equipos de protección personal pasan por estrictos controles de calidad durante la fabricación y cumplen con las certificaciones vigentes."
      },
      {
        question: "¿Los EPP cumplen con las normativas nacionales e internacionales?",
        answer: "Sí, nuestros elementos de protección personal cumplen con las normativas nacionales e internacionales de seguridad y salud laboral aplicables a cada producto."
      },
      {
        question: "¿Cuánto tiempo duran los EPP antes de necesitar un reemplazo?",
        answer: "La vida útil depende del tipo de elemento y de las condiciones de uso. Te asesoramos sobre los periodos de reemplazo recomendados para mantener la protección adecuada."
      }
    ]
  },
  {
    id: "calzado-seguridad",
    title: "Calzado de Seguridad",
    faqs: [
      {
        question: "¿Qué propiedades tiene nuestro calzado?",
        answer: "Nuestro calzado está fabricado con materiales de primera calidad que ofrecen resistencia, comodidad y protección, cumpliendo con las normativas de seguridad vigentes."
      },
      {
        question: "¿Qué garantías ofrecen en el calzado de seguridad y cuál es su vida útil?",
        answer: "Ofrecemos garantía sobre defectos de fabricación. La vida útil depende del uso y mantenimiento, pero está diseñado para soportar exigentes condiciones de trabajo."
      },
      {
        question: "¿Qué normas de seguridad cumple el calzado de seguridad?",
        answer: "Nuestro calzado cumple con las normas nacionales e internacionales de seguridad industrial aplicables, garantizando la protección del trabajador."
      },
      {
        question: "¿Tienen opciones para trabajos especializados?",
        answer: "Sí, contamos con líneas de calzado especializado para diferentes entornos y riesgos laborales, adaptadas a las necesidades específicas de cada sector."
      }
    ]
  }
];
---

<Layout title="Preguntas Frecuentes | Agencias Nacionales S.A.S">
  <Navbar />
  <main class="w-full bg-white">
    <!-- Hero Section -->
    <section class="w-full sm:px-4 lg:px-6 mt-4">
      <div class="relative w-full h-[450px] overflow-hidden bg-stone-800 sm:rounded-3xl md:h-[500px]">
        <img src={bannerFAQ.src} alt="Preguntas frecuentes Agencias Nacionales" class="absolute inset-0 h-full w-full object-cover" />
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="absolute inset-0 z-10 flex h-full items-center justify-center px-6">
          <div class="w-full max-w-[90%] text-center sm:mx-auto sm:max-w-4xl lg:max-w-6xl">
            <h1 class="mt-3 text-2xl font-extrabold leading-tight text-white drop-shadow-lg sm:mt-5 sm:text-4xl lg:text-5xl">
              Preguntas frecuentes
            </h1>
            <p class="mt-3 max-w-lg text-base leading-relaxed text-white/95 drop-shadow sm:mx-auto sm:mt-4 sm:text-lg font-medium">
              Resuelve tus dudas más comunes sobre nuestros productos y servicios rápidamente.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Content -->
    <section class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 items-start">

        <!-- Left Column: Fixed Category Nav -->
        <aside id="faq-aside" class="w-full lg:w-[28%]">
          <nav id="faq-nav" class="flex flex-col border-l border-gray-200 items-center lg:pt-24">
            {categories.map((cat) => (
              <a
                href={`#${cat.id}`}
                data-faq-link={cat.id}
                class="faq-nav-link -ml-px border-l-2 border-transparent py-2.5 pl-5 text-[18px] text-gray-500 transition-colors hover:text-gray-900 text-center"
              >
                {cat.title}
              </a>
            ))}
          </nav>
        </aside>

        <!-- Right Column: Grouped Accordions -->
        <div class="w-full lg:w-[72%] flex flex-col gap-12">
          {categories.map((cat) => (
            <div id={cat.id} data-faq-section={cat.id} class="scroll-mt-28">
              <div class="rounded-2xl border border-gray-100 bg-white px-6 py-5 shadow-sm mb-4">
                <h2 class="text-xl font-semibold text-gray-900">{cat.title}</h2>
              </div>
              <div class="flex flex-col gap-3">
                {cat.faqs.map((faq) => (
                  <div class="faq-item rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                    <button class="faq-button flex w-full cursor-pointer items-center justify-between gap-1.5 font-medium text-gray-900 outline-none text-left">
                      <h3 class="text-[15px] pr-4">{faq.question}</h3>
                      <span class="relative h-5 w-5 shrink-0 text-gray-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="faq-icon-closed absolute inset-0 h-5 w-5 opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                        <svg xmlns="http://www.w3.org/2000/svg" class="faq-icon-opened absolute inset-0 h-5 w-5 opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
                        </svg>
                      </span>
                    </button>
                    <div class="faq-content grid grid-rows-[0fr] transition-all duration-300 ease-in-out">
                      <div class="overflow-hidden">
                        <div class="pt-4">
                          <p class="leading-relaxed text-gray-600 text-[14px]">
                            {faq.answer}
                          </p>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  // Accordion behavior
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(item => {
    const button = item.querySelector('.faq-button');
    const content = item.querySelector('.faq-content');
    const iconClosed = item.querySelector('.faq-icon-closed');
    const iconOpened = item.querySelector('.faq-icon-opened');

    button?.addEventListener('click', () => {
      const isOpen = content?.classList.contains('grid-rows-[1fr]');

      faqItems.forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.querySelector('.faq-content')?.classList.remove('grid-rows-[1fr]');
          otherItem.querySelector('.faq-content')?.classList.add('grid-rows-[0fr]');
          otherItem.querySelector('.faq-icon-closed')?.classList.replace('opacity-0', 'opacity-100');
          otherItem.querySelector('.faq-icon-opened')?.classList.replace('opacity-100', 'opacity-0');
        }
      });

      if (isOpen) {
        content?.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
        iconClosed?.classList.replace('opacity-0', 'opacity-100');
        iconOpened?.classList.replace('opacity-100', 'opacity-0');
      } else {
        content?.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
        iconClosed?.classList.replace('opacity-100', 'opacity-0');
        iconOpened?.classList.replace('opacity-0', 'opacity-100');
      }
    });
  });

  // Active category highlighting (scroll-spy)
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.faq-nav-link');
  const sections = document.querySelectorAll<HTMLElement>('[data-faq-section]');

  const activeClasses = ['border-blue-600', 'text-gray-900', 'font-semibold'];
  const inactiveClasses = ['border-transparent', 'text-gray-500'];

  function setActive(id: string) {
    navLinks.forEach(link => {
      const isActive = link.dataset.faqLink === id;
      activeClasses.forEach(c => link.classList.toggle(c, isActive));
      inactiveClasses.forEach(c => link.classList.toggle(c, !isActive));
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActive((entry.target as HTMLElement).dataset.faqSection ?? '');
        }
      });
    },
    { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
  );

  sections.forEach(section => observer.observe(section));

  // Fixed sidebar: keep the nav static on scroll, aligned with its placeholder
  const aside = document.getElementById('faq-aside');
  const nav = document.getElementById('faq-nav');
  const TOP_OFFSET = 112; // px (matches lg:top-28)

  function syncNav() {
    if (!aside || !nav) return;
    const isDesktop = window.matchMedia('(min-width: 1024px)').matches;

    if (!isDesktop) {
      nav.style.position = '';
      nav.style.top = '';
      nav.style.left = '';
      nav.style.width = '';
      return;
    }

    const rect = aside.getBoundingClientRect();
    const container = aside.parentElement; // flex row, ends where the FAQ content ends

    // Only fix the nav once the sidebar reaches the top offset (i.e. after the
    // banner). While the banner is still visible, keep the nav in normal flow.
    if (rect.top <= TOP_OFFSET) {
      const navHeight = nav.offsetHeight;

      // Clamp the top so the nav stops before the footer instead of overlapping it.
      let top = TOP_OFFSET;
      if (container) {
        const maxTop = container.getBoundingClientRect().bottom - navHeight;
        if (top > maxTop) top = maxTop;
      }

      // Fill the column so the nav stays centered (items-center) within it.
      nav.style.position = 'fixed';
      nav.style.top = `${top}px`;
      nav.style.left = `${rect.left}px`;
      nav.style.width = `${rect.width}px`;
    } else {
      nav.style.position = '';
      nav.style.top = '';
      nav.style.left = '';
      nav.style.width = '';
    }
  }

  syncNav();
  window.addEventListener('resize', syncNav);
  window.addEventListener('scroll', syncNav, { passive: true });
</script>
