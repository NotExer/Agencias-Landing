---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import bannerBlog from "../img/Banner politica seguridad.jpg";
import PoliticaSeguridadContent from "../components/PoliticaSeguridad.astro";
---

<Layout title="Politica seguridad| Agencias Nacionales S.A.S">
  <Navbar />
  <main class="w-full bg-white">
    <!-- Hero Section -->
    <section class="w-full sm:px-4 lg:px-6 mt-4">
      <div class="relative w-full h-[450px] overflow-hidden bg-stone-800 sm:rounded-3xl md:h-[500px]">
        <img
          src={bannerBlog.src}
          alt="Blog Agencias Nacionales"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="absolute inset-0 z-10 flex h-full items-center justify-center px-6">
          <div class="w-full max-w-[90%] text-center sm:mx-auto sm:max-w-4xl lg:max-w-6xl">
            <h1 class="mt-3 text-2xl font-extrabold leading-tight text-white drop-shadow-lg sm:mt-5 sm:text-4xl lg:text-5xl">
              Politica seguridad
            </h1>
            <p class="mt-3 max-w-lg text-base leading-relaxed text-white/95 drop-shadow sm:mx-auto sm:mt-4 sm:text-lg font-medium">
              Fomentamos un ambiente laboral seguro y saludable, priorizando el bienestar y la seguridad de nuestros empleados.
            </p>
          </div>
        </div>
      </div>
    </section>
    <PoliticaSeguridadContent />
  </main>
  <Footer />
</Layout>
