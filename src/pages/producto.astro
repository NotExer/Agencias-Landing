---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import {
  products,
  categories,
  productHref,
  categorySlug,
} from "../data/catalog";

function formatPrice(n: number) {
  return new Intl.NumberFormat("es-CO", {
    style: "currency",
    currency: "COP",
    maximumFractionDigits: 0,
  }).format(n);
}

const baseBtn = "px-4 py-1.5 rounded-full text-m font-medium transition border";
const activeBtn = baseBtn + " bg-[#2B395E] text-white border-transparent";
const inactiveBtn =
  baseBtn + " bg-white text-gray-600 border-gray-200 hover:border-gray-400";
---

<Layout title="Productos | Agencias Nacionales S.A.S">
  <Navbar />
  <main class="w-full bg-white min-h-screen">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-4">
      <h1 class="text-2xl font-bold text-gray-900">Todos los productos</h1>
      <p id="product-count" class="text-m text-gray-500 mt-1">
        {products.length} productos disponibles
      </p>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
      <div class="flex flex-wrap gap-2">
        <a href="/producto" id="btn-all" class={inactiveBtn}>Todos</a>
        {
          categories.map((cat) => (
            <a
              href={`/producto?categoria=${categorySlug(cat.label)}`}
              class={`cat-btn ${inactiveBtn}`}
              data-slug={categorySlug(cat.label)}
            >
              {cat.label}
            </a>
          ))
        }
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <p id="no-products" class="text-center text-gray-400 py-20 hidden">
        No hay productos en esta categoría.
      </p>
      <ul
        id="product-list"
        class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-8"
      >
        {
          products.map((product) => (
            <li
              class="product-item"
              data-category={categorySlug(product.category)}
            >
              <a href={productHref(product.name)} class="group flex flex-col">
                <div class="relative aspect-square w-full overflow-hidden rounded-2xl bg-gray-50">
                  <img
                    src={product.images[0]}
                    alt={product.name}
                    class:list={[
                      "h-full w-full object-contain p-4 transition-opacity duration-200",
                      product.images[1] && "group-hover:opacity-0",
                    ]}
                    loading="lazy"
                  />
                  {product.images[1] && (
                    <img
                      src={product.images[1]}
                      alt={product.name}
                      class="absolute inset-0 h-full w-full object-contain p-4 opacity-0 transition-opacity duration-200 group-hover:opacity-100"
                      loading="lazy"
                    />
                  )}
                  {!product.inStock && (
                    <span class="absolute top-3 left-3 rounded-full bg-gray-800/70 px-2.5 py-1 text-[11px] font-medium text-white">
                      Agotado
                    </span>
                  )}
                </div>
                <div class="mt-3 px-0.5">
                  <p class="text-xs text-gray-400 mb-0.5">{product.category}</p>
                  <p class="text-m font-medium text-gray-900 leading-snug line-clamp-2 group-hover:text-blue-600 transition-colors">
                    {product.name}
                  </p>
                  <p class="mt-1.5 text-base font-bold text-gray-900">
                    {formatPrice(product.price)}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <Footer />

  <script is:inline>
    function initFilters() {
      // Solo ejecutar en la página de productos
      const productList = document.getElementById("product-list");
      if (!productList) return;

      // Clases de estilos
      const ACTIVE =
        "px-4 py-1.5 rounded-full text-m font-medium transition border bg-[#2B395E] text-white border-transparent";
      const INACTIVE =
        "px-4 py-1.5 rounded-full text-m font-medium transition border bg-white text-gray-600 border-gray-200 hover:border-gray-400";

      const catParam =
        new URLSearchParams(window.location.search).get("categoria") || "";
      const items = document.querySelectorAll(".product-item");
      const catBtns = document.querySelectorAll(".cat-btn");
      const btnAll = document.getElementById("btn-all");
      const countEl = document.getElementById("product-count");
      const noProducts = document.getElementById("no-products");

      // Aplicar filtro
      let visible = 0;
      items.forEach(function (item) {
        var show = !catParam || item.dataset.category === catParam;
        item.style.display = show ? "" : "none";
        if (show) visible++;
      });

      // Resaltar botón activo
      if (btnAll) btnAll.className = catParam ? INACTIVE : ACTIVE;
      catBtns.forEach(function (btn) {
        btn.className = btn.dataset.slug === catParam ? ACTIVE : INACTIVE;
      });

      // Contador y mensaje vacío
      if (countEl) countEl.textContent = visible + " productos disponibles";
      if (noProducts) noProducts.style.display = visible === 0 ? "block" : "none";
      if (productList) productList.style.display = visible === 0 ? "none" : "";
    }

    // Ejecutar al cargar la página (con o sin View Transitions)
    document.addEventListener("astro:page-load", initFilters);
  </script>
</Layout>
