---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { products, categories, productHref } from "../data/catalog";

const categoriaParam = Astro.url.searchParams.get("categoria");

function formatPrice(n: number) {
  return new Intl.NumberFormat("es-CO", {
    style: "currency",
    currency: "COP",
    maximumFractionDigits: 0,
  }).format(n);
}

function catSlug(label: string) {
  return label.toLowerCase().replace(/\s+/g, "-");
}

const baseBtn = "px-4 py-1.5 rounded-full text-sm font-medium transition border";
const activeBtn = baseBtn + " bg-[#2B395E] text-white border-transparent";
const inactiveBtn = baseBtn + " bg-white text-gray-600 border-gray-200 hover:border-gray-400";

// ← Todo pre-calculado aquí, nada de lógica en el template
const categoryLinks = categories.map((cat) => ({
  label:    cat.label,
  href:     "/producto?categoria=" + catSlug(cat.label),
  isActive: categoriaParam === catSlug(cat.label),
}));

const filtrados = categoriaParam
  ? products.filter((p) => catSlug(p.category) === categoriaParam)
  : products;
---

<Layout title="Productos | Agencias Nacionales S.A.S">
  <Navbar />
  <main class="w-full bg-white min-h-screen">

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-4">
      <h1 class="text-2xl font-bold text-gray-900">Todos los productos</h1>
      <p class="text-sm text-gray-500 mt-1">{filtrados.length} productos disponibles</p>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
      <div class="flex flex-wrap gap-2">
        <a href="/producto" class={!categoriaParam ? activeBtn : inactiveBtn}>Todos</a>
        {categoryLinks.map((cat) => (
          <a href={cat.href} class={cat.isActive ? activeBtn : inactiveBtn}>
            {cat.label}
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      {filtrados.length === 0 && (
        <p class="text-center text-gray-400 py-20">No hay productos en esta categoría.</p>
      )}
      {filtrados.length > 0 && (
        <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-8">
          {filtrados.map((product) => (
            <li>
              <a href={productHref(product.name)} class="group flex flex-col">
                <div class="relative aspect-square w-full overflow-hidden rounded-2xl bg-gray-50">
                  <img
                    src={product.images[0]}
                    alt={product.name}
                    class="h-full w-full object-contain p-4 transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                  {!product.inStock && (
                    <span class="absolute top-3 left-3 rounded-full bg-gray-800/70 px-2.5 py-1 text-[11px] font-medium text-white">
                      Agotado
                    </span>
                  )}
                </div>
                <div class="mt-3 px-0.5">
                  <p class="text-xs text-gray-400 mb-0.5">{product.category}</p>
                  <p class="text-sm font-medium text-gray-900 leading-snug line-clamp-2 group-hover:text-blue-600 transition-colors">
                    {product.name}
                  </p>
                  <p class="mt-1.5 text-base font-bold text-gray-900">
                    {formatPrice(product.price)}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

  </main>
  <Footer />
</Layout>