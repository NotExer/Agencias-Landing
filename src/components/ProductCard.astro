---
interface Props {
  image: string;
  name: string;
  price: string;
  rating: string;
}

const { image, name, price, rating } = Astro.props;
---

<article class="group flex w-full flex-col">
  <div class="flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl bg-gray-50 p-4">
    <img
      src={image}
      alt={name}
      class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <h3 class="mt-3 text-sm text-gray-700">{name}</h3>
  <div class="mt-1 flex items-center justify-between">
    <p class="text-sm font-bold text-gray-900">{price} COP</p>
    <div class="flex items-center gap-1 text-xs text-gray-400">
      <svg class="h-3.5 w-3.5 fill-amber-400" viewBox="0 0 20 20">
        <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.42 4.36a1 1 0 00.95.69h4.58c.97 0 1.37 1.24.59 1.81l-3.71 2.7a1 1 0 00-.36 1.12l1.42 4.36c.3.92-.76 1.69-1.54 1.12l-3.71-2.7a1 1 0 00-1.18 0l-3.71 2.7c-.78.57-1.84-.2-1.54-1.12l1.42-4.36a1 1 0 00-.36-1.12l-3.71-2.7c-.78-.57-.38-1.81.59-1.81h4.58a1 1 0 00.95-.69L9.05 2.93z" />
      </svg>
      <span>{rating}</span>
    </div>
  </div>
</article>
