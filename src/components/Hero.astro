---
import banner1 from "../img/banner1.png";
import banner2 from "../img/banner2.png";
import banner3 from "../img/banner3.png";
import people1 from "../img/people 1.avif";
import people2 from "../img/people 2.avif";
import people3 from "../img/people 3.avif";

const slides = [
  {
    image: banner1.src,
    align: "right",
    badge: true,
    title: "Protección y Confianza en Cada Paso",
    text: "Uniformes y calzado industrial diseñados para la seguridad, comodidad y durabilidad que tu equipo necesita. Innovamos para proteger a los que mueven el mundo.",
    cta: "VER MÁS",
    overlay: "bg-gradient-to-r from-black/70 via-black/40 to-transparent",
  },
  {
    image: banner2.src,
    align: "left",
    badge: false,
    title: "Un equipo que trabaja para ti",
    text: "Más de 55 años de experiencia ofreciendo soluciones en calzado, uniformes, EPP e indumentaria hospitalaria, con calidad, seguridad y confianza para tu negocio.",
    cta: "VER MÁS",
    overlay: "bg-gradient-to-r from-black/75 via-black/45 to-transparent",
  },
  {
    image: banner3.src,
    align: "left",
    badge: false,
    title: "¡Envío Gratis en Compras en el Área Metropolitana!",
    text: "Aprovecha esta oferta y recibe tus productos de manera rápida y segura sin costo adicional. ¡Protege a tu equipo sin preocuparte por el envío! Para otras ciudades validar cobertura.",
    cta: "VER MÁS",
    overlay: "bg-gradient-to-r from-blue-950/80 via-blue-900/40 to-transparent",
  },
];

const content = slides[0];

const stats = [
  { value: "+56", label: "Años de experiencia" },
  { value: "+700", label: "Empresas confían en nosotros" },
  { value: "3", label: "Puntos de operación" },
  { value: "+50", label: "Aliados estratégicos" },
];
---

<section id="inicio" class="w-full sm:px-4 lg:px-6">
  <div
    id="hero-carousel"
    class="relative w-full h-[580px] overflow-hidden bg-stone-800 sm:rounded-3xl lg:h-[700px]"
  >
    <!-- Slides Track -->
    <div
      id="carousel-track"
      class="flex h-full w-full transition-transform duration-500 ease-in-out"
      style="transform: translateX(-3000%);"
    >
      {/* Clones para scroll súper rápido hacia atrás (10 sets) */}
      {
        Array.from({ length: 10 })
          .flatMap(() => slides)
          .map((slide) => (
            <div class="relative h-full w-full shrink-0" aria-hidden="true">
              <img
                src={slide.image}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
              />
              <div class={`absolute inset-0 ${slide.overlay}`} />

              <div class="absolute inset-0 z-10 flex h-full items-center px-6 pb-48 sm:px-12 sm:pb-36 lg:px-16">
                <div class="w-full max-w-[90%] text-left sm:mx-auto sm:max-w-4xl lg:max-w-6xl sm:text-center">
                  <div class="flex flex-col gap-3 sm:items-center">
                    <div class="flex items-center gap-1 text-amber-400">
                      {Array.from({ length: 5 }).map(() => (
                        <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                          <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.42 4.36a1 1 0 00.95.69h4.58c.97 0 1.37 1.24.59 1.81l-3.71 2.7a1 1 0 00-.36 1.12l1.42 4.36c.3.92-.76 1.69-1.54 1.12l-3.71-2.7a1 1 0 00-1.18 0l-3.71 2.7c-.78.57-1.84-.2-1.54-1.12l1.42-4.36a1 1 0 00-.36-1.12l-3.71-2.7c-.78-.57-.38-1.81.59-1.81h4.58a1 1 0 00.95-.69L9.05 2.93z" />
                        </svg>
                      ))}
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="flex -space-x-2">
                        <img
                          src={people1.src}
                          alt=""
                          class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                        />
                        <img
                          src={people2.src}
                          alt=""
                          class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                        />
                        <img
                          src={people3.src}
                          alt=""
                          class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                        />
                      </div>
                      <div class="leading-tight text-left">
                        <p class="text-sm font-bold text-white">+3000</p>
                        <p class="text-[10px] text-white/70">
                          Clientes felices
                        </p>
                      </div>
                    </div>
                  </div>
                  <h1
                    class="mt-3 text-xl font-extrabold leading-tight text-white drop-shadow-lg sm:mt-5 sm:text-4xl lg:text-4xl"
                    set:html={slide.title}
                  />
                  <p class="mt-3 max-w-md text-l leading-relaxed text-white/85 drop-shadow sm:mx-auto sm:mt-4 sm:text-sm">
                    {slide.text}
                  </p>
                  <a
                    href="#productos"
                    class="mt-4 inline-flex rounded-full bg-blue-950 px-5 py-2 text-xs font-semibold text-white shadow-lg transition hover:bg-blue-800 sm:mt-6 sm:px-7 sm:py-3 sm:text-sm"
                  >
                    {slide.cta}
                  </a>
                </div>
              </div>
            </div>
          ))
      }

      {/* Slides reales */}
      {
        slides.map((slide, index) => (
          <div class="relative h-full w-full shrink-0" data-slide={index}>
            <img
              src={slide.image}
              alt=""
              class="absolute inset-0 h-full w-full object-cover"
            />
            <div class={`absolute inset-0 ${slide.overlay}`} />

            <div class="absolute inset-0 z-10 flex h-full items-center px-6 pb-48 sm:px-12 sm:pb-36 lg:px-16">
              <div class="w-full max-w-[90%] text-left sm:mx-auto sm:max-w-4xl lg:max-w-6xl sm:text-center">
                <div class="flex flex-col gap-3 sm:items-center">
                  <div class="flex items-center gap-1 text-amber-400">
                    {Array.from({ length: 5 }).map(() => (
                      <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                        <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.42 4.36a1 1 0 00.95.69h4.58c.97 0 1.37 1.24.59 1.81l-3.71 2.7a1 1 0 00-.36 1.12l1.42 4.36c.3.92-.76 1.69-1.54 1.12l-3.71-2.7a1 1 0 00-1.18 0l-3.71 2.7c-.78.57-1.84-.2-1.54-1.12l1.42-4.36a1 1 0 00-.36-1.12l-3.71-2.7c-.78-.57-.38-1.81.59-1.81h4.58a1 1 0 00.95-.69L9.05 2.93z" />
                      </svg>
                    ))}
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="flex -space-x-2">
                      <img
                        src={people1.src}
                        alt=""
                        class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                      />
                      <img
                        src={people2.src}
                        alt=""
                        class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                      />
                      <img
                        src={people3.src}
                        alt=""
                        class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                      />
                    </div>
                    <div class="leading-tight text-left">
                      <p class="text-sm font-bold text-white">+3000</p>
                      <p class="text-[10px] text-white/70">Clientes felices</p>
                    </div>
                  </div>
                </div>
                <h1
                  class="mt-3 text-xl font-extrabold leading-tight text-white drop-shadow-lg sm:mt-5 sm:text-4xl lg:text-4xl"
                  set:html={slide.title}
                />
                <p class="mt-3 max-w-md text-l leading-relaxed text-white/85 drop-shadow sm:mx-auto sm:mt-4 sm:text-sm">
                  {slide.text}
                </p>
                <a
                  href="#productos"
                  class="mt-4 inline-flex rounded-full bg-blue-950 px-5 py-2 text-xs font-semibold text-white shadow-lg transition hover:bg-blue-800 sm:mt-6 sm:px-7 sm:py-3 sm:text-sm"
                >
                  {slide.cta}
                </a>
              </div>
            </div>
          </div>
        ))
      }

      {/* Clones para scroll súper rápido hacia adelante (10 sets) */}
      {
        Array.from({ length: 10 })
          .flatMap(() => slides)
          .map((slide) => (
            <div class="relative h-full w-full shrink-0" aria-hidden="true">
              <img
                src={slide.image}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
              />
              <div class={`absolute inset-0 ${slide.overlay}`} />

              <div class="absolute inset-0 z-10 flex h-full items-center px-6 pb-48 sm:px-12 sm:pb-36 lg:px-16">
                <div class="w-full max-w-[90%] text-left sm:mx-auto sm:max-w-4xl lg:max-w-6xl sm:text-center">
                  <div class="flex flex-col gap-3 sm:items-center">
                    <div class="flex items-center gap-1 text-amber-400">
                      {Array.from({ length: 5 }).map(() => (
                        <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                          <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.42 4.36a1 1 0 00.95.69h4.58c.97 0 1.37 1.24.59 1.81l-3.71 2.7a1 1 0 00-.36 1.12l1.42 4.36c.3.92-.76 1.69-1.54 1.12l-3.71-2.7a1 1 0 00-1.18 0l-3.71 2.7c-.78.57-1.84-.2-1.54-1.12l1.42-4.36a1 1 0 00-.36-1.12l-3.71-2.7c-.78-.57-.38-1.81.59-1.81h4.58a1 1 0 00.95-.69L9.05 2.93z" />
                        </svg>
                      ))}
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="flex -space-x-2">
                        <img
                          src={people1.src}
                          alt=""
                          class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                        />
                        <img
                          src={people2.src}
                          alt=""
                          class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                        />
                        <img
                          src={people3.src}
                          alt=""
                          class="h-8 w-8 rounded-full border-2 border-white/40 object-cover"
                        />
                      </div>
                      <div class="leading-tight text-left">
                        <p class="text-sm font-bold text-white">+3000</p>
                        <p class="text-[10px] text-white/70">
                          Clientes felices
                        </p>
                      </div>
                    </div>
                  </div>
                  <h1
                    class="mt-3 text-xl font-extrabold leading-tight text-white drop-shadow-lg sm:mt-5 sm:text-4xl lg:text-4xl"
                    set:html={slide.title}
                  />
                  <p class="mt-3 max-w-md text-l leading-relaxed text-white/85 drop-shadow sm:mx-auto sm:mt-4 sm:text-sm">
                    {slide.text}
                  </p>
                  <a
                    href="#productos"
                    class="mt-4 inline-flex rounded-full bg-blue-950 px-5 py-2 text-xs font-semibold text-white shadow-lg transition hover:bg-blue-800 sm:mt-6 sm:px-7 sm:py-3 sm:text-sm"
                  >
                    {slide.cta}
                  </a>
                </div>
              </div>
            </div>
          ))
      }
    </div>

    <!-- Prev / Next buttons -->
    <div class="absolute right-5 top-5 z-20 flex gap-2">
      <button
        type="button"
        data-carousel-prev
        aria-label="Anterior"
        class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur transition hover:bg-white/40"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
      <button
        type="button"
        data-carousel-next
        aria-label="Siguiente"
        class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur transition hover:bg-white/40"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Dots -->
    <div
      class="absolute bottom-[12rem] left-1/2 z-20 flex -translate-x-1/2 gap-2"
    >
      {
        slides.map((_, index) => (
          <button
            type="button"
            data-carousel-dot={index}
            aria-label={`Ir al banner ${index + 1}`}
            class:list={[
              "h-2 rounded-full bg-white transition-all duration-300",
              index === 0 ? "w-6 opacity-100" : "w-2 opacity-50",
            ]}
          />
        ))
      }
    </div>

    <!-- Glass stat cards -->
    <div
      class="absolute inset-x-0 bottom-0 z-20 p-3 sm:p-4 md:p-5 lg:p-8 grid grid-cols-2 gap-px md:grid-cols-4"
    >
      {
        stats.map((stat) => (
          <div class="border-t border-white/10 bg-white/30 px-3 py-2 sm:px-4 sm:py-3 md:px-4 md:py-4 lg:px-6 lg:py-6 backdrop-blur-md m-1 sm:m-1.5 md:m-1.5 lg:m-2 rounded-lg">
            <p class="text-lg text-white sm:text-xl md:text-2xl lg:text-3xl">
              {stat.value}
            </p>
            <p class="mt-0.5 text-[10px] leading-tight text-white/80 sm:mt-1 sm:text-xs md:text-sm lg:text-base">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById("hero-carousel");
  if (carousel) {
    const track = document.getElementById("carousel-track");
    const dots = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-carousel-dot]"),
    );
    const prev = carousel.querySelector<HTMLElement>("[data-carousel-prev]");
    const next = carousel.querySelector<HTMLElement>("[data-carousel-next]");

    const N = dots.length;
    const cloneSets = 10; // 10 sets a la izquierda y 10 a la derecha
    const realBase = cloneSets * N; // El índice base donde empiezan los slides reales
    const totalSlides = N + cloneSets * 2 * N;

    let current = realBase;
    let timer: ReturnType<typeof setInterval>;
    let transitionTimeout: ReturnType<typeof setTimeout>;
    let lastClickTime = 0;

    const updateDots = () => {
      const activeDotIndex = ((current % N) + N) % N;
      dots.forEach((dot, i) => {
        const active = i === activeDotIndex;
        dot.classList.toggle("w-6", active);
        dot.classList.toggle("opacity-100", active);
        dot.classList.toggle("w-2", !active);
        dot.classList.toggle("opacity-50", !active);
      });
    };

    const jumpIfNeeded = () => {
      if (!track) return;
      if (current >= realBase + N || current < realBase) {
        const offset = ((current % N) + N) % N;
        current = realBase + offset;

        track.style.transition = "none";
        track.style.transform = `translateX(-${current * 100}%)`;
        track.getBoundingClientRect(); // forzar reflow
      }
    };

    const show = (newIndex: number) => {
      if (!track) return;

      // Límite físico extremo (solo se alcanzaría tras decenas de clicks por segundo)
      if (newIndex >= totalSlides) newIndex = totalSlides - 1;
      if (newIndex < 0) newIndex = 0;

      current = newIndex;
      track.style.transition = "";
      track.style.transform = `translateX(-${current * 100}%)`;

      updateDots();

      clearTimeout(transitionTimeout);
      transitionTimeout = setTimeout(() => {
        jumpIfNeeded();
      }, 500);
    };

    const go = (delta: number) => {
      const now = Date.now();
      if (now - lastClickTime >= 500) {
        jumpIfNeeded();
      }
      lastClickTime = now;
      show(current + delta);
      restart();
    };

    const goToDot = (dotIndex: number) => {
      const now = Date.now();
      if (now - lastClickTime >= 500) {
        jumpIfNeeded();
      }
      lastClickTime = now;
      const currentMod = ((current % N) + N) % N;
      const delta = dotIndex - currentMod;
      show(current + delta);
      restart();
    };

    const restart = () => {
      clearInterval(timer);
      timer = setInterval(() => go(1), 6000);
    };

    prev?.addEventListener("click", () => go(-1));
    next?.addEventListener("click", () => go(1));
    dots.forEach((dot, i) => dot.addEventListener("click", () => goToDot(i)));

    updateDots();
    restart();
  }
</script>
