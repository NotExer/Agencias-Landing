---
const faqs = [
  {
    question: "¿Cuánto tiempo tarda el proceso de producción de uniformes personalizados?",
    answer: "Dependiendo de la prenda y de la cantidad, el tiempo máximo del proceso es de 45 días calendario."
  },
  {
    question: "¿Cuáles son las técnicas de marcación que ofrecen para los uniformes?",
    answer: "Ofrecemos diversas técnicas de marcación como bordado, serigrafía y vinilo textil, adaptadas a tus necesidades para asegurar durabilidad y calidad."
  },
  {
    question: "¿Hacen envíos a nivel nacional e internacional?",
    answer: "Sí, realizamos envíos seguros y confiables tanto a nivel nacional como internacional para llegar a donde nos necesites."
  },
  {
    question: "¿Cuál es el proceso para solicitar una cotización?",
    answer: "Puedes solicitarla a través de nuestro botón 'Escríbenos' o contactándonos directamente. Nuestro equipo te guiará paso a paso según tus requerimientos."
  },
  {
    question: "¿Qué materiales utilizan en sus uniformes y calzado de seguridad?",
    answer: "Utilizamos materiales de primera calidad y tecnología avanzada para asegurar resistencia, comodidad y el estricto cumplimiento de normativas de seguridad."
  },
  {
    question: "¿Cómo aseguran la durabilidad del equipo de protección personal?",
    answer: "Nuestros equipos de protección personal pasan por estrictos controles de calidad durante la fabricación y cumplen con las certificaciones vigentes."
  },
  {
    question: "¿Realizan pruebas de resistencia en sus productos?",
    answer: "Sí, todos nuestros productos son sometidos a rigurosas pruebas de resistencia para garantizar la máxima protección y rendimiento de tu equipo."
  }
];
---

<section id="faq" class="w-full px-8 py-16 sm:px-6 lg:px-40 bg-gray-50/50">
  <div class="mx-auto flex flex-col lg:flex-row max-w-6xl gap-16 items-start relative">
    
    <!-- Left Column: Accordions -->
    <div class="w-full lg:w-[60%] flex flex-col gap-3">
      {faqs.map((faq, index) => (
         <div class="faq-item rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition hover:shadow-md">
           <button class="faq-button flex w-full cursor-pointer items-center justify-between gap-1.5 font-medium text-gray-900 outline-none text-left">
             <h3 class="text-[15px] pr-4">{faq.question}</h3>
             <span class="relative h-5 w-5 shrink-0 text-gray-500">
               <svg xmlns="http://www.w3.org/2000/svg" class="faq-icon-closed absolute inset-0 h-5 w-5 opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
               </svg>
               <svg xmlns="http://www.w3.org/2000/svg" class="faq-icon-opened absolute inset-0 h-5 w-5 opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
               </svg>
             </span>
           </button>
           <div class="faq-content grid grid-rows-[0fr] transition-all duration-300 ease-in-out">
             <div class="overflow-hidden">
               <div class="pt-4">
                 <p class="leading-relaxed text-gray-600 text-[14px]">
                   {faq.answer}
                 </p>
               </div>
             </div>
           </div>
         </div>
      ))}
    </div>

    <!-- Right Column: Sticky Text -->
    <div class="w-full lg:w-[40%] lg:sticky lg:top-50 mt-8 lg:mt-0 pt-2">
       <p class="text-sm font-semibold text-blue-500 mb-3">Preguntas frecuentes</p>
       <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl mb-6 leading-tight">
         ¿Tienes alguna pregunta?
       </h2>
       <p class="text-gray-700 text-[16px] mb-6 leading-relaxed">
         Habla con nuestro equipo de lunes a viernes entre las 7am - 4:30pm
       </p>
       <a href="#" class="inline-block text-blue-600 font-semibold hover:text-blue-800 transition-colors">
         Escríbenos
       </a>
    </div>

  </div>
</section>

<script>
  const faqItems = document.querySelectorAll('.faq-item');
  
  faqItems.forEach(item => {
    const button = item.querySelector('.faq-button');
    const content = item.querySelector('.faq-content');
    const iconClosed = item.querySelector('.faq-icon-closed');
    const iconOpened = item.querySelector('.faq-icon-opened');
    
    button?.addEventListener('click', () => {
      const isOpen = content?.classList.contains('grid-rows-[1fr]');
      
      // Opcional: cierra los demás automáticamente al abrir uno
      faqItems.forEach(otherItem => {
        if(otherItem !== item) {
           otherItem.querySelector('.faq-content')?.classList.remove('grid-rows-[1fr]');
           otherItem.querySelector('.faq-content')?.classList.add('grid-rows-[0fr]');
           otherItem.querySelector('.faq-icon-closed')?.classList.replace('opacity-0', 'opacity-100');
           otherItem.querySelector('.faq-icon-opened')?.classList.replace('opacity-100', 'opacity-0');
        }
      });

      if (isOpen) {
        content?.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
        iconClosed?.classList.replace('opacity-0', 'opacity-100');
        iconOpened?.classList.replace('opacity-100', 'opacity-0');
      } else {
        content?.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
        iconClosed?.classList.replace('opacity-100', 'opacity-0');
        iconOpened?.classList.replace('opacity-0', 'opacity-100');
      }
    });
  });
</script>
