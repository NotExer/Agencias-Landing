---
import bannerImg from '../img/banner-footer.jpg';
---

<section class="w-full px-4 py-5 sm:px-6 lg:px-10 xl:px-10 bg-white">
  <div class="relative w-full h-[450px] md:h-[500px] rounded-[32px] overflow-hidden shadow-xl mx-auto max-w-[1400px]">
    <!-- Fondo de imagen -->
    <img 
      src={bannerImg.src} 
      alt="Instalaciones industriales" 
      class="absolute inset-0 w-full h-full object-cover"
    />
    
    <!-- Filtro oscuro (más fuerte a la izquierda) -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent"></div>

    <!-- Contenido -->
    <div class="relative w-full h-full px-8 md:px-16 flex flex-col justify-center">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-[42px] lg:text-[48px] font-bold text-white leading-[1.1] mb-5 tracking-tight">
          Todo lo que tu equipo necesita, en un solo lugar
        </h2>
        <p class="text-[17px] text-gray-200 mb-10 leading-relaxed max-w-[600px]">
          Explora nuestra amplia gama de productos diseñados para ofrecer calidad, seguridad y comodidad en cada detalle.
        </p>
        
        <div class="flex flex-wrap items-center gap-8">
          <a href="#" class="inline-block bg-[#3c4e75] hover:bg-[#2c3a57] text-white font-semibold text-[15px] px-8 py-3.5 rounded-full transition-colors shadow-lg">
            Contáctanos
          </a>
          <a href="#" class="inline-flex items-center gap-1.5 text-white font-bold text-[15px] hover:text-gray-300 transition-colors">
            Ver productos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
