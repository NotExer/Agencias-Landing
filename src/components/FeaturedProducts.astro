---
import ProductCard from "./ProductCard.astro";
import p1 from "../img/Producto 1.avif";
import p2 from "../img/Producto 2.avif";
import p3 from "../img/Producto 3.avif";
import p5 from "../img/Producto 5.avif";
import ProductDetail from "./ProductDetail.astro";

const products = [
  {
    image: p1.src,
    name: "Bota Soldador Inyectada",
    price: "NaN",
    rating: "NaN (1)",
  },
  {
    image: p2.src,
    name: "Pantalon Dril Clasico Hombre Caqui",
    price: "NaN",
    rating: "NaN (1)",
  },
  {
    image: p3.src,
    name: "Blue Jean Clasico Dama-Pret. Anat.",
    price: "NaN",
    rating: "NaN (1)",
  },
  {
    image: p5.src,
    name: "Pantalon Dril Clasico Hombre Azul Osc",
    price: "NaN",
    rating: "NaN (8)",
  },
];
---

<section id="productos" class="w-full px-8 py-8 sm:px-6 lg:px-40">
  <div class="flex items-center justify-between">
    <h2 class="text-2xl font-extrabold text-gray-900 sm:text-3xl">
      Los más frecuentes
    </h2>
    <a
      href="#productos"
      class="flex items-center gap-1 text-sm font-medium text-gray-500 hover:text-blue-600"
    >
      Ver todos
      <svg
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </a>
  </div>

  <div class="relative mt-8">
    <div
      class="flex snap-x snap-mandatory gap-5 overflow-x-auto pb-2 sm:grid sm:grid-cols-3 sm:overflow-visible lg:grid-cols-4"
    >
      {
        products.map((product) => (
          <div class="w-full shrink-0 snap-start sm:w-auto sm:shrink">
            <ProductCard {...product} />
          </div>
        ))
      }
    </div>

    <button
      type="button"
      aria-label="Siguiente"
      class="absolute -right-3 top-1/2 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white text-gray-500 shadow-lg ring-1 ring-gray-100 transition hover:text-blue-600 lg:flex"
    >
      <svg
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </button>
  </div>
</section>
