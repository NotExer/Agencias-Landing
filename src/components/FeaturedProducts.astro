---
import { products, productHref } from "../data/catalog";

// Muestra los primeros 4 productos del catálogo
const featured = products.slice(0, 4);

function formatPrice(n: number) {
  return new Intl.NumberFormat("es-CO", {
    style: "currency",
    currency: "COP",
    maximumFractionDigits: 0,
  }).format(n);
}
---

<section id="productos" class="w-full px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-extrabold text-gray-900 sm:text-3xl">
        Los más frecuentes
      </h2>
      <a
        href="/producto"
        class="flex items-center gap-1 text-m font-medium text-gray-500 hover:text-blue-600 transition-colors"
      >
        Ver todos
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
    </div>

    <div class="relative">
      <!-- Track con scroll horizontal en móvil, grid en desktop -->
      <div
        id="featured-track"
        class="flex snap-x snap-mandatory gap-5 overflow-x-auto pb-2 sm:grid sm:grid-cols-3 sm:overflow-visible lg:grid-cols-4"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {
          featured.map((product) => (
            <a
              href={productHref(product.name)}
              class="group flex w-56 shrink-0 snap-start flex-col sm:w-auto sm:shrink"
            >
              <div class="flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl bg-gray-50 p-4">
                <img
                  src={product.images[0]}
                  alt={product.name}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <div class="mt-3">
                <p class="text-xs text-gray-400 mb-0.5">{product.category}</p>
                <h3 class="text-m text-gray-700 line-clamp-2 group-hover:text-blue-600 transition-colors">
                  {product.name}
                </h3>
                <div class="mt-1">
                  <p class="text-m font-bold text-gray-900">
                    {formatPrice(product.price)}
                  </p>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Botón siguiente (visible solo en móvil/tablet donde hay scroll) -->
      <button
        id="featured-next"
        type="button"
        aria-label="Siguiente"
        class="absolute -right-3 top-1/3 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white text-gray-500 shadow-lg ring-1 ring-gray-100 transition hover:text-blue-600 sm:hidden"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById("featured-track") as HTMLElement | null;
  const nextBtn = document.getElementById("featured-next");

  if (track && nextBtn) {
    nextBtn.addEventListener("click", () => {
      const cardWidth = track.querySelector("a")?.offsetWidth ?? 224;
      track.scrollBy({ left: cardWidth + 20, behavior: "smooth" });
    });

    // Ocultar botón al llegar al final
    track.addEventListener(
      "scroll",
      () => {
        const atEnd =
          track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;
        nextBtn.style.opacity = atEnd ? "0" : "1";
        nextBtn.style.pointerEvents = atEnd ? "none" : "auto";
      },
      { passive: true },
    );
  }
</script>
