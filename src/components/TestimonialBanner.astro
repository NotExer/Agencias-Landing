---
const testimonials = [
  "Contratamos a Agencias Nacionales para dotar a nuestra empresa con uniformes personalizados, y superaron nuestras expectativas. Los materiales son cómodos y duraderos, y la personalización quedó perfecta. Muy recomendados.",
  "Desde que comenzamos a trabajar con Agencias Nacionales, nuestros empleados están encantados con sus nuevos uniformes. Además, el enfoque ambiental de la empresa es un gran plus para nosotros.",
  "Los precios son competitivos, considerando la calidad de los productos. Hubo un pequeño inconveniente con una talla, pero lo resolvieron rápidamente.",
  "El equipo fue muy atento y respondió rápidamente a todas nuestras inquietudes. Los uniformes llegaron antes del plazo estimado y en perfectas condiciones. Definitivamente trabajaremos con ellos de nuevo.",
];

const cloneSets = 1;
---

<section class="mx-auto w-full px-4 py-8 sm:px-6 lg:px-8">
  <div class="rounded-3xl bg-blue-950 px-6 py-12 text-white sm:px-12">
    <div class="grid min-w-0 items-center gap-8 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-extrabold leading-tight sm:text-4xl">
          Más de 2.000 clientes<br />han hablado
        </h2>
        <div class="mt-4 flex items-center gap-1 text-amber-400">
          {
            Array.from({ length: 5 }).map(() => (
              <svg class="h-5 w-5 fill-current" viewBox="0 0 20 20">
                <path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.42 4.36a1 1 0 00.95.69h4.58c.97 0 1.37 1.24.59 1.81l-3.71 2.7a1 1 0 00-.36 1.12l1.42 4.36c.3.92-.76 1.69-1.54 1.12l-3.71-2.7a1 1 0 00-1.18 0l-3.71 2.7c-.78.57-1.84-.2-1.54-1.12l1.42-4.36a1 1 0 00-.36-1.12l-3.71-2.7c-.78-.57-.38-1.81.59-1.81h4.58a1 1 0 00.95-.69L9.05 2.93z" />
              </svg>
            ))
          }
        </div>
        <a
          href="#resenas"
          class="mt-4 inline-flex items-center gap-1 text-m font-semibold text-white/90 hover:text-white"
        >
          Ver todas
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div
        class="flex min-w-0 items-center justify-between w-full gap-2 sm:gap-4"
      >
        <button
          type="button"
          id="testim-prev"
          aria-label="Anterior"
          class="flex h-10 w-10 shrink-0 items-center justify-center text-white/70 transition hover:text-white"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>

        <div
          class="min-w-0 flex-1 min-h-[100px] overflow-hidden flex items-center"
        >
          <div
            id="testimonial-track"
            class="flex w-full transition-transform duration-500 ease-in-out"
          >
            {
              Array.from({ length: cloneSets * 2 + 1 })
                .flatMap(() => testimonials)
                .map((text) => (
                  <div class="w-full shrink-0 flex items-center justify-center">
                    <p class="text-center text-m leading-relaxed text-white/90 max-w-sm mx-auto px-4 sm:px-0">
                      {text}
                    </p>
                  </div>
                ))
            }
          </div>
        </div>

        <button
          type="button"
          id="testim-next"
          aria-label="Siguiente"
          class="flex h-10 w-10 shrink-0 items-center justify-center text-white/70 transition hover:text-white"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById("testimonial-track");
  const prevBtn = document.getElementById("testim-prev");
  const nextBtn = document.getElementById("testim-next");

  if (track && prevBtn && nextBtn) {
    const N = 4; // Cantidad original de testimonios
    const cloneSets = 1; // Sets de clones a cada lado
    const realBase = cloneSets * N; // Índice inicial (empezamos en el set real del medio)

    let current = realBase;
    let transitionTimeout: ReturnType<typeof setTimeout> | undefined;

    // Posicionamiento inicial sin animación
    track.style.transition = "none";
    track.style.transform = `translateX(-${current * 100}%)`;
    track.getBoundingClientRect(); // Forzar reflow

    // Función para reposicionar silenciosamente cuando nos alejamos del centro
    const jumpIfNeeded = () => {
      if (current >= realBase + N || current < realBase) {
        const offset = ((current % N) + N) % N;
        current = realBase + offset;

        track.style.transition = "none";
        track.style.transform = `translateX(-${current * 100}%)`;
        track.getBoundingClientRect(); // Forzar reflow
      }
    };

    const updateSlide = () => {
      track.style.transition = "transform 500ms ease-in-out";
      track.style.transform = `translateX(-${current * 100}%)`;

      clearTimeout(transitionTimeout);
      transitionTimeout = setTimeout(() => {
        jumpIfNeeded();
      }, 500); // 500ms debe coincidir con el tiempo de la transición CSS
    };

    prevBtn.addEventListener("click", () => {
      current--;
      updateSlide();
    });

    nextBtn.addEventListener("click", () => {
      current++;
      updateSlide();
    });
  }
</script>
