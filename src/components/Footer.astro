---
import logo from "../img/Icono footer.png";
---

<footer class="w-full px-1 sm:px-5 lg:px-10 xl:px-10 bg-white pb-5">
  <div
    class="relative w-full rounded-[32px] bg-[#1a1c1d] max-w-[1400px] mx-auto px-8 md:px-16 py-16"
  >
    <!-- Top Section: Newsletter -->
    <div
      class="flex flex-col lg:flex-row justify-between items-center gap-10 mb-20"
    >
      <div class="w-full lg:w-1/2">
        <h2
          class="text-3xl md:text-[34px] font-semibold text-white leading-tight max-w-[500px]"
        >
          Recibe las mejores ofertas y novedades antes que nadie
        </h2>
      </div>
      <div class="w-full lg:w-1/2 max-w-[550px]">
        <p class="text-[15px] text-white mb-4 leading-relaxed">
          Suscríbete a nuestro boletín y mantente al día con promociones
          exclusivas, nuevos lanzamientos y contenido útil para tu negocio.
        </p>
        <form
          class="flex w-full max-w-full items-center bg-white rounded-full overflow-hidden p-1"
        >
          <input
            type="email"
            placeholder="nombre@gmail.com"
            class="w-full min-w-0 flex-1 bg-transparent px-3 sm:px-4 py-2 outline-none text-gray-800 text-[14px] sm:text-[15px]"
            required
          />
          <button
            type="submit"
            class="shrink-0 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 sm:px-6 py-2 sm:py-2.5 rounded-full transition-colors text-[14px] sm:text-[15px]"
          >
            Suscribirme
          </button>
        </form>
      </div>
    </div>

    <!-- Middle Section: Links -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-16">
      <!-- Logo & Description (takes 2 columns on lg) -->
      <div class="lg:col-span-2">
        <!-- Logo en escala de grises con brillo para parecer blanco (si el original es oscuro) o normal -->
        <img
          src={logo.src}
          alt="Agencias Nacionales S.A.S"
          class="h-20 w-auto mb-6 backdrop-blur-sm"
        />
        <p class="text-[14px] leading-relaxed text-gray-400 max-w-[300px]">
          Fabricamos uniformes y calzado de trabajo con calidad, seguridad y
          sostenibilidad, adaptados a las necesidades de cada cliente.
        </p>
      </div>

      <!-- Navegación -->
      <div>
        <h3 class="text-[15px] font-bold text-white mb-5">Navegación</h3>
        <ul class="space-y-3">
          {
            [
              "Nosotros",
              "FAQ",
              "Blog",
              "Política ambiental",
              "Política de seguridad",
              "Política de calidad",
              "Política de privacidad",
            ].map((link) => (
              <li>
                <a
                  href="#"
                  class="text-gray-400 hover:text-white text-[14px] transition-colors"
                >
                  {link}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Comprar -->
      <div>
        <h3 class="text-[15px] font-bold text-white mb-5">Comprar</h3>
        <ul class="space-y-3">
          {
            [
              "Tulas",
              "Prendas de Vestir",
              "Impermeables",
              "Habitaciones",
              "Cirugía",
              "Accesorios",
              "Uniformes Operativos",
              "Seguridad",
              "Comercial",
              "Colegio",
            ].map((link) => (
              <li>
                <a
                  href="#"
                  class="text-gray-400 hover:text-white text-[14px] transition-colors"
                >
                  {link}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-[15px] font-bold text-white mb-5">Contacto</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="#"
              class="text-gray-400 hover:text-white text-[14px] transition-colors"
              >Contáctanos</a
            >
          </li>
          <li>
            <a
              href="mailto:contactanos@agenciasnacionales.com"
              class="text-gray-400 hover:text-white text-[14px] transition-colors"
              >contactanos@agenciasnacionales.com</a
            >
          </li>
          <li>
            <a
              href="tel:3042351036"
              class="text-gray-400 hover:text-white text-[14px] transition-colors"
              >304 2351036</a
            >
          </li>
          <li><span class="text-gray-400 text-[14px]">(604) 322 2292</span></li>
          <li>
            <span
              class="text-gray-400 hover:text-white text-[14px] transition-colors"
              >Agencias Nacionales SAS. Carrera, 47 20 Sur Zona 2, Envigado,
              Antioquia</span
            >
          </li>
        </ul>

        <!-- Social Icons -->
        <div class="mt-6 flex gap-3">
          <a href="#" class="text-white hover:text-white-500 transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path></svg
            >
          </a>
          <a href="#" class="text-white hover:text-white-500 transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
          <a href="#" class="text-white hover:text-white-500 transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-gray-800 text-[13px]"
    >
      <p class="text-[#3b82f6]">
        © Agencias Nacionales 2026. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-[#3b82f6] hover:text-blue-400 transition-colors"
          >Política de privacidad</a
        >
        <a href="#" class="text-[#3b82f6] hover:text-blue-400 transition-colors"
          >Términos de uso</a
        >
      </div>
    </div>

    <!-- Floating WhatsApp Button (Visual representation) -->
    <a
      href="#"
      class="absolute -bottom-4 -right-4 md:-bottom-2 md:-right-6 bg-black text-white p-3 rounded-full shadow-2xl hover:scale-110 transition-transform"
    >
      <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"
        ><path
          d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.964 9.964 0 001.333 4.975L2 22l5.233-1.337a10.024 10.024 0 004.779 1.206c5.503 0 9.984-4.479 9.985-9.985S17.518 2 12.012 2zm.006 16.59c-1.488 0-2.946-.386-4.237-1.116l-.303-.173-3.14.802.839-3.003-.195-.315c-.815-1.309-1.246-2.825-1.245-4.398.002-4.572 3.722-8.293 8.296-8.293 2.215 0 4.298.864 5.864 2.433 1.564 1.567 2.428 3.652 2.428 5.868-.002 4.575-3.725 8.298-8.298 8.298zm4.55-6.22c-.25-.125-1.478-.73-1.706-.813-.228-.083-.396-.125-.562.125-.167.25-.644.813-.79.98-.146.166-.291.187-.542.062-1.32-.656-2.316-1.196-3.238-2.65-.083-.131.066-.118.297-.565.083-.166.042-.312-.02-.437-.063-.125-.563-1.354-.771-1.854-.203-.49-.41-.424-.563-.432l-.48-.008c-.167 0-.438.063-.667.313-.229.25-.875.854-.875 2.083s.896 2.417 1.021 2.583c.125.167 1.761 2.688 4.267 3.771 1.722.744 2.378.847 3.2.716.637-.101 1.478-.604 1.686-1.188.208-.583.208-1.083.146-1.188-.063-.104-.229-.166-.479-.291z"
        ></path></svg
      >
    </a>
  </div>
</footer>
