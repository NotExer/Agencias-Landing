---
import { categories as catalogCats, categorySlug } from "../data/catalog";

import imgCalzado      from "../img/Categoria calzado.webp";
import imgUniformes    from "../img/Categoria uniforme.webp";
import imgEPP          from "../img/Categoria EPP.jpeg";
import imgHospitalaria from "../img/Categoria hospitalarios.jpg";

// Mapa de imagen por nombre de categoría
const categoryImages: Record<string, { src: string; width: number; height: number }> = {
  "Calzado de Trabajo":   imgCalzado,
  "Uniformes de Trabajo": imgUniformes,
  "EPP":                  imgEPP,
  "Hospitalaria":         imgHospitalaria,
};

// Construye las 4 categorías con imagen
const categoriesWithImage = catalogCats
  .filter((c) => categoryImages[c.label])
  .map((c) => ({
    name:    c.label,
    count:   `${c.products.length} Producto${c.products.length !== 1 ? "s" : ""}`,
    href:    `/producto?categoria=${categorySlug(c.label)}`,
    img:     categoryImages[c.label],
  }));
---

<section id="categorias" class="w-full px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <h2 class="text-2xl font-extrabold text-gray-900 sm:text-3xl mb-8">
      Explora nuestras categorías
    </h2>

    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      {categoriesWithImage.map((cat) => (
        <a
          href={cat.href}
          class="group relative flex aspect-square flex-col justify-end overflow-hidden rounded-2xl shadow-sm transition hover:shadow-xl"
        >
          <!-- Imagen de fondo -->
          <img
            src={cat.img.src}
            alt={cat.name}
            width={cat.img.width}
            height={cat.img.height}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <!-- Overlay degradado -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
          <!-- Texto -->
          <div class="relative p-4 text-white">
            <h3 class="text-base font-bold leading-tight sm:text-lg">{cat.name}</h3>
            <p class="mt-0.5 text-xs text-white/80 sm:text-sm">{cat.count}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
