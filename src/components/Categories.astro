---
const categories = [
  {
    name: "Calzado de trabajo",
    count: "4 Productos",
    gradient: "from-emerald-600 to-emerald-800",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14l-1 12H6L5 8zM9 8V6a3 3 0 016 0v2" />`,
  },
  {
    name: "Prendas de Vestir",
    count: "13 Productos",
    gradient: "from-green-500 to-emerald-700",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16 4l4 3-2 4-2-1v10H8V10L6 11 4 7l4-3 2 2h4l2-2z" />`,
  },
  {
    name: "Seguiridad",
    count: "4 Productos",
    gradient: "from-emerald-500 to-green-700",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16v12H4V8zM4 8l2-4h12l2 4" />`,
  },
  {
    name: "Hospitalarios",
    count: "9 Productos",
    gradient: "from-sky-500 to-cyan-700",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-8 9 8M5 10v10h14V10" />`,
  },
];
---

<section id="categorias" class="w-full px-8 py-8 sm:px-6 lg:px-40">
  <h2 class="text-2xl font-extrabold text-gray-900 sm:text-3xl">
    Explora nuestras categorias
  </h2>

  <div class="relative mt-8">
    <div class="grid grid-cols-2 gap-5 lg:grid-cols-4">
      {
        categories.map((category) => (
          <a
            href="#productos"
            class={`group relative flex aspect-square flex-col justify-end overflow-hidden rounded-2xl bg-gradient-to-br ${category.gradient} p-5 text-white shadow-sm transition hover:shadow-xl`}
          >
            <svg
              class="absolute right-4 top-4 h-16 w-16 text-white/15"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              set:html={category.icon}
            />
            <h3 class="text-lg font-bold">{category.name}</h3>
            <p class="text-sm text-white/80">{category.count}</p>
          </a>
        ))
      }
    </div>

    <button
      type="button"
      aria-label="Siguiente"
      class="absolute -right-3 top-1/2 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white text-gray-500 shadow-lg ring-1 ring-gray-100 transition hover:text-blue-600 lg:flex"
    >
      <svg
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </button>
  </div>
</section>
