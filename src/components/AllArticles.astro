---
import blog1 from "../img/Blog 1.avif";
import blog2 from "../img/Blog 2.avif";

interface Article {
  image: string | null;
  tag: string;
  date: string;
  title: string;
  href: string;
}

const articles: Article[] = [
  {
    image: blog1.src,
    tag: "Tips",
    date: "21 may 2026",
    title: "Cómo cotizar dotaciones empresariales sin errores: guía para compras y SST",
    href: "#",
  },
  {
    image: blog2.src,
    tag: "Tips",
    date: "20 nov 2023",
    title: "Agencias Nacionales SAS reconocida por el Banco de Bogotá como finalista en el premio Gacela misiónpyme 2024.",
    href: "#",
  },
  {
    image: blog1.src,
    tag: "Tips",
    date: "24 ene 2025",
    title: "Más que uniformes: Vestimos el trabajo con calidad y compromiso",
    href: "#",
  },
  {
    image: blog1.src,
    tag: "Tips",
    date: "22 may 2026",
    title: "Cada cuánto renovar uniformes, calzado de trabajo y EPP en una empresa: guía para compras y SST",
    href: "#",
  },
  {
    image: null,
    tag: "Tips",
    date: "25 may 2026",
    title: "Cómo elegir calzado de trabajo para tu empresa según riesgo, superficie y jornada",
    href: "#",
  },
  {
    image: null,
    tag: "Tips",
    date: "25 may 2026",
    title: "Cómo estandarizar dotaciones por cargo y área sin disparar costos en tu empresa",
    href: "#",
  },
];
---

<section id="todos-los-articulos" class="w-full px-8 py-16 sm:px-6 lg:px-20 xl:px-40 bg-white">
  <div class="text-center mb-10">
    <h2 class="text-3xl font-extrabold text-gray-900 sm:text-[34px] tracking-tight">
      Todos los artículos
    </h2>
  </div>

  <div class="mx-auto w-full max-w-6xl grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2">
    {
      articles.map((article) => (
        <a href={article.href} class="group flex flex-col gap-4 sm:flex-row sm:gap-5">
          <div class="aspect-[16/10] w-full shrink-0 overflow-hidden rounded-xl bg-gray-100 sm:w-44">
            {article.image ? (
              <img
                src={article.image}
                alt={article.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="h-full w-full bg-[repeating-linear-gradient(135deg,#f3f4f6_0px,#f3f4f6_8px,#e5e7eb_8px,#e5e7eb_16px)]" />
            )}
          </div>
          <div class="flex flex-1 flex-col justify-center">
            <div class="mb-2 flex items-center gap-3">
              <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600">
                {article.tag}
              </span>
              <span class="text-xs text-gray-400">{article.date}</span>
            </div>
            <h3 class="text-base font-semibold leading-snug text-gray-900 transition-colors group-hover:text-blue-600 sm:text-[17px]">
              {article.title}
            </h3>
          </div>
        </a>
      ))
    }
  </div>
</section>