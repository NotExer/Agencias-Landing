---
// Reusable product detail template.
// Pasa los datos del producto como props desde la página.

interface Highlight {
  icon: "durabilidad" | "comodidad" | "personalizable";
  label: string;
}

interface Props {
  name: string;
  price: number;
  images: string[]; // [0] = imagen principal, el resto = miniaturas
  highlights?: Highlight[]; // 3 destacados con ícono
  description: string[]; // un string por párrafo
  inStock?: boolean;
  contactHref?: string;
  info?: { title: string; content: string };
}

const {
  name,
  price,
  images = [],
  highlights = [],
  description = [],
  inStock = true,
  contactHref = "/contacto",
  info,
} = Astro.props;

const mainImage = images[0];
const thumbs = images;
---

<section class="mx-auto w-full max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">
    <!-- ============ GALERÍA ============ -->
    <div class="w-full lg:w-1/2 flex flex-col-reverse sm:flex-row gap-4">
      <!-- Miniaturas -->
      {
        thumbs.length > 1 && (
          <div class="flex sm:flex-col gap-3 overflow-x-auto sm:overflow-visible">
            {thumbs.map((img, i) => (
              <button
                type="button"
                data-thumb={img}
                class={`product-thumb shrink-0 h-20 w-20 overflow-hidden rounded-xl border-2 bg-gray-50 p-1.5 transition ${i === 0 ? "border-blue-600" : "border-transparent hover:border-gray-200"}`}
              >
                <img
                  src={img}
                  alt={`${name} vista ${i + 1}`}
                  class="h-full w-full object-contain"
                />
              </button>
            ))}
          </div>
        )
      }

      <!-- Imagen principal -->
      <div
        class="flex flex-1 items-start justify-start overflow-hidden rounded-3xl bg-gray-50 p-6"
      >
        <img
          id="product-main-image"
          src={mainImage}
          alt={name}
          class="max-h-[480px] w-full object-contain"
        />
      </div>
    </div>

    <!-- ============ INFORMACIÓN ============ -->
    <div class="w-full lg:w-1/2">
      <h1 class="text-2xl font-extrabold text-gray-900 sm:text-3xl mb-8">
        {name}
      </h1>

      <!-- Destacados -->
      {
        highlights.length > 0 && (
          <div class="grid grid-cols-3 gap-4 mb-8">
            {highlights.map((h) => (
              <div class="flex flex-col items-center text-center gap-2">
                <span class="text-blue-600">
                  {h.icon === "durabilidad" && (
                    <svg
                      class="h-9 w-9"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.7"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"
                      />
                    </svg>
                  )}
                  {h.icon === "comodidad" && (
                    <svg
                      class="h-9 w-9"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.7"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
                      />
                    </svg>
                  )}
                  {h.icon === "personalizable" && (
                    <svg
                      class="h-9 w-9"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.7"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a6.759 6.759 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.281z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                  )}
                </span>
                <p class="text-m font-medium text-gray-700">{h.label}</p>
              </div>
            ))}
          </div>
        )
      }

      <!-- Descripción -->
      <div class="space-y-4 mb-8">
        {
          description.map((p) => (
            <p class="text-m  leading-relaxed text-gray-600">{p}</p>
          ))
        }
      </div>

      <p class="text-2xl font-bold text-gray-900">
        {
          new Intl.NumberFormat("es-CO", {
            style: "currency",
            currency: "COP",
            maximumFractionDigits: 0,
          }).format(price)
        }
      </p>

      <!-- Stock -->
      <div class="flex items-center gap-2 mb-6">
        <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
        <span class="text-m font-medium text-gray-700">{"Disponible"}</span>
      </div>

      <!-- Botón Contáctanos -->
      <a
        href={contactHref}
        class="block w-full rounded-full bg-green-600 py-4 text-center text-m font-medium text-white transition hover:bg-green-700"
      >
        Contáctanos
      </a>

      <!-- Garantías -->
      <div class="grid grid-cols-3 gap-4 mt-8">
        <div class="flex flex-col items-center text-center gap-2 text-blue-600">
          <svg
            class="h-9 w-9"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"
            ></path>
          </svg>
          <p class="text-m font-medium text-gray-700">Compra Segura</p>
        </div>
        <div class="flex flex-col items-center text-center gap-2 text-blue-600">
          <svg
            class="h-9 w-9"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
            ></path>
          </svg>
          <p class="text-m font-medium text-gray-700">Entrega en 7-14 días</p>
        </div>
        <div class="flex flex-col items-center text-center gap-2 text-blue-600">
          <svg
            class="h-9 w-9"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 12a8.25 8.25 0 0116.5 0v6.75a2.25 2.25 0 01-2.25 2.25H15a.75.75 0 01-.75-.75v-3.75a.75.75 0 01.75-.75h3v-3a6.75 6.75 0 00-13.5 0v3h3a.75.75 0 01.75.75v3.75a.75.75 0 01-.75.75H4.5a2.25 2.25 0 01-2.25-2.25V12z"
            ></path>
          </svg>
          <p class="text-m font-medium text-gray-700">Soporte 24/7</p>
        </div>
      </div>

      <!-- Información (acordeón) -->
      {
        info && (
          <div class="mt-8 border-t border-gray-200 pt-6">
            <button
              id="product-info-button"
              class="flex w-full items-center justify-between text-left"
            >
              <span class="text-lg font-semibold text-gray-900">
                {info.title}
              </span>
              <svg
                id="product-info-icon"
                class="h-5 w-5 text-gray-500 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div
              id="product-info-content"
              class="grid grid-rows-[1fr] transition-all duration-300 ease-in-out"
            >
              <div class="overflow-hidden">
                <p class="pt-4 text-m  leading-relaxed text-gray-500">
                  {info.content}
                </p>
              </div>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  function initProductDetail() {
    // Galería: cambiar imagen principal al hacer clic en miniatura
    const mainImg = document.getElementById(
      "product-main-image",
    ) as HTMLImageElement | null;
    const thumbs = document.querySelectorAll<HTMLButtonElement>(".product-thumb");

    thumbs.forEach((thumb) => {
      // Remove previous listener if any to avoid duplicates
      thumb.removeEventListener("click", thumbClickHandler);
      thumb.addEventListener("click", thumbClickHandler);
      
      function thumbClickHandler() {
        const src = thumb.dataset.thumb;
        if (mainImg && src) mainImg.src = src;
        thumbs.forEach((t) => {
          t.classList.toggle("border-blue-600", t === thumb);
          t.classList.toggle("border-transparent", t !== thumb);
        });
      }
    });

    // Acordeón "Información"
    const infoBtn = document.getElementById("product-info-button");
    const infoContent = document.getElementById("product-info-content");
    const infoIcon = document.getElementById("product-info-icon");

    if (infoBtn) {
      infoBtn.removeEventListener("click", toggleInfo);
      infoBtn.addEventListener("click", toggleInfo);
    }

    function toggleInfo() {
      const isOpen = infoContent?.classList.contains("grid-rows-[1fr]");
      if (isOpen) {
        infoContent?.classList.replace("grid-rows-[1fr]", "grid-rows-[0fr]");
        infoIcon?.classList.add("rotate-180");
      } else {
        infoContent?.classList.replace("grid-rows-[0fr]", "grid-rows-[1fr]");
        infoIcon?.classList.remove("rotate-180");
      }
    }
  }

  document.addEventListener("astro:page-load", initProductDetail);
</script>
