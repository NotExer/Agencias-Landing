---
import aboutImg from "../img/Familia.about.avif";

const features = [
  {
    title: "Calidad garantizada",
    text: "Diseñamos prendas y calzado con materiales de alta resistencia para ofrecer durabilidad y comodidad incluso en las condiciones más exigentes.",
  },
  {
    title: "Compromiso Ambiental",
    text: "Integramos prácticas sostenibles en nuestros procesos, reduciendo el impacto ambiental sin comprometer la calidad.",
  },
  {
    title: "Personalización Completa",
    text: "Creamos uniformes que reflejan la identidad de tu empresa, adaptados a tus requerimientos y al entorno laboral.",
  },
  {
    title: "Cumplimiento Legal y Normativo",
    text: "Nuestros productos cumplen con todas las normativas de seguridad y calidad, garantizando protección y confianza.",
  },
];
---

<section id="nosotros" class="w-full px-8 py-8 sm:px-6 lg:px-40">
  <div class="grid items-center gap-10 lg:grid-cols-2">
    <div>
      <p class="text-m font-semibold text-blue-600">Sobre nosotros</p>
      <h2
        class="mt-2 text-3xl font-extrabold leading-tight text-gray-900 sm:text-4xl"
      >
        Comprometidos con Tu<br class="hidden sm:block" /> Seguridad y Confort
      </h2>
      <p class="mt-4 max-w-md text-m leading-relaxed text-gray-500">
        Descubre cómo garantizamos calidad, durabilidad y diseño en cada prenda
        y calzado que fabricamos para el éxito de tu equipo
      </p>
      <a
        href="#nosotros"
        class="mt-5 inline-flex items-center gap-1 text-m font-semibold text-gray-900 hover:text-blue-600"
      >
        Conócenos más
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
    </div>

    <div class="overflow-hidden rounded-2xl bg-gray-50">
      <img
        src={aboutImg.src}
        alt="Equipo de Agencias Nacionales"
        width={aboutImg.width}
        height={aboutImg.height}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover"
      />
    </div>
  </div>

  <div class="mt-10 grid gap-x-12 gap-y-12 sm:grid-cols-2">
    {
      features.map((feature) => (
        <div class="border-b border-gray-100 pb-6">
          <div class="flex items-center gap-3">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-white">
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"
                />
              </svg>
            </span>
            <h3 class="text-base font-bold text-gray-900">{feature.title}</h3>
          </div>
          <p class="mt-3 text-m leading-relaxed text-black">{feature.text}</p>
        </div>
      ))
    }
  </div>
</section>
